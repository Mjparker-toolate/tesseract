# Spotify Developer app — https://developer.spotify.com/dashboard
# Redirect URI to set in the dashboard: http://127.0.0.1:8888/callback
SPOTIFY_CLIENT_ID=your_client_id_here

# Optional. Leave empty to use PKCE flow (recommended for CLI use — no
# secret needed). Only set this if you explicitly want the classic
# Authorization-Code flow.
SPOTIFY_CLIENT_SECRET=

SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Optional — enables tag-based vibe modelling.
# Get a free key at https://www.last.fm/api/account/create
LASTFM_API_KEY=

# Where the SQLite cache and auth token live. Defaults to ~/.spotify-recommender.
# Point this at a cloud-synced folder (Dropbox/iCloud Drive/Google Drive) to
# share the cache across devices.
# SPOTIFY_RECOMMENDER_HOME=
